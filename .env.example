# You normally do NOT create this by hand: infra/deploy.sh GENERATES a ready-to-use
# .env (endpoint + key + every knob below, pre-filled with the published-run values).
# This template is for a manual run without deploy.sh, or as a reference for the knobs.
#
# To change the run, override any knob in the environment BEFORE deploy, e.g.:
#   COSMOS_MAX_THROUGHPUT=20000 GEN_ORDERS_PER_DAY=200 ./run-all.sh   (cheaper/smaller)
# deploy.sh bakes whatever you set into .env; the generator + both query clients read it.
# NEVER commit the real .env (it holds the primary key).

# --- Deploy-time knob (read by infra/deploy.sh, not the apps) ---
# Autoscale max RU/s during load. ~10000 RU/s => one physical partition, so 100000
# forces ~10 partitions (the published layout). This is the main cost lever.
COSMOS_MAX_THROUGHPUT=100000

# --- Cosmos DB account (from infra/deploy.sh output, `az cosmosdb show`, or portal) ---
COSMOS_ENDPOINT=https://<account-name>.documents.azure.com:443/
# Primary key (`az cosmosdb keys list --query primaryMasterKey`). Account-key auth.
COSMOS_KEY=<primary-key>

# Database + container names (must match infra/main.parameters.json)
COSMOS_DATABASE=ordersdb
COSMOS_CONTAINER=orders

# --- Data generator (src/DataGenerator) — these values yield the ~1.27M-doc dataset ---
GEN_START_DATE=2024-01-01
GEN_NUM_DAYS=1000
GEN_ORDERS_PER_DAY=1000        # published run = 1000/day (1000 days ≈ 1.0M base docs)
GEN_BATCH_SIZE=1000
GEN_BUSY_MONTH=true            # make month 2024-06 heavier so it straddles a partition split
GEN_BUSY_MONTH_MULT=10         # 2024-06 gets 10x docs (+270k) → ~1.27M total
# Autoscale max the generator requests ONLY if it has to create the container itself.
# In the normal flow deploy.sh already created it at COSMOS_MAX_THROUGHPUT, so this is
# ignored; deploy.sh sets it equal to COSMOS_MAX_THROUGHPUT for consistency.
GEN_AUTOSCALE_MAX=100000

# --- Query clients (src/DotNetQueryClient + src/go-query-client) ---
SWEEP_MAX_CONCURRENCY=6        # concurrency sweep runs 1..N for each query config
CELL_SECONDS=10               # seconds per sweep cell (code default is 12; published run used 10)

# --- Scale-down (infra/scale-down.sh) ---
# Idle autoscale-max floor after the load window. For a container that burst to
# 100000 RU/s the minimum is 10000 (= max(1000, highest/10)); 10000 RU/s bills
# ~US$29/day. See the cost warning in README.md.
TARGET_MAX=10000
